# App
# Listen port for `pnpm dev` / `pnpm start` (default 3000). Next.js reads `PORT`.
# When `NEXT_PUBLIC_APP_URL` is omitted, the app uses http://localhost:${PORT} everywhere
# (including Auth.js); `next.config.ts` injects that for you—no separate AUTH_URL.
PORT=3000
# Set only when the public URL is not localhost (e.g. production):
# NEXT_PUBLIC_APP_URL=https://mentora.example.com
NODE_ENV=development

# Auth.js
AUTH_SECRET=replace-with-long-random-string

# Email (magic link). In development, links are printed to the server console.
EMAIL_FROM=no-reply@mentora.local

# Database
DATABASE_URL=postgresql://mentora:mentora@localhost:5432/mentora?schema=public

# Platform defaults (used only when seeding policy row)
SEED_ADMIN_EMAIL=admin@mentora.local
SEED_ADMIN_PASSWORD=ChangeMe123!
